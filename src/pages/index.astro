---
import Layout from '../layouts/Layout.astro';
import GameGrid from '../components/GameGrid.jsx';
---
 
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet" />
</head>
<body>
 
  <!-- ── NAVBAR ── -->
  <nav class="navbar">
    <a href="/" class="logo">
      <span class="logo-icon">◈</span>
      <span class="logo-text">CHECKPOINT</span>
    </a>
      <div class="nav-search">
    <span class="search-icon">⌕</span>
    <input
      type="text"
      id="nav-search-input"
      placeholder="Buscar juego..."
      autocomplete="off"
    />
  </div>
  <div class="nav-right">
    <button id="login-btn" class="auth-btn">Iniciar sesión</button>
    <button id="signup-btn" class="auth-btn outline">Crear cuenta</button>
  </div>

  <div id="login-dropdown" class="login-dropdown hidden">
    <span id="close-login" class="close">✕</span>

    <input type="text" placeholder="Username" />
    <input type="password" placeholder="Password" />

    <div class="login-actions">
      <label>
        <input type="checkbox" />
        recordame
      </label>  
      <button class="signin-btn">SIGN IN</button>
    </div>
  </div>
  </nav>
 
 
  <!-- ── REACT COMPONENT ── -->
  <GameGrid client:load />
  <div id="signup-modal" class="modal hidden">
  <div class="modal-box">
    <span id="close-signup" class="close">✕</span>

    <h2>Crear cuenta</h2>

    <input type="text" placeholder="Nombre de usuario" />
    <input type="email" placeholder="Email" />
    <input type="password" placeholder="Contraseña" />

    <button class="submit-btn">Registrarse</button>
  </div>
</div>
 <script>
const input = document.getElementById('nav-search-input')! as HTMLInputElement;

  input.addEventListener('input', (e) => {
    const target = e.target as HTMLInputElement;
    window.dispatchEvent(
      new CustomEvent('checkpoint-search', { detail: target.value })
    );
  });

  // 🔐 AUTH

  const loginBtn = document.getElementById('login-btn')!;
  const signupBtn = document.getElementById('signup-btn')!;

  const loginDropdown = document.getElementById('login-dropdown')!;
  const signupModal = document.getElementById('signup-modal')!;

  const closeLogin = document.getElementById('close-login')!;
  const closeSignup = document.getElementById('close-signup')!;

  // abrir login (dropdown)
  loginBtn.onclick = () => {
    loginDropdown.classList.toggle('hidden');
    signupModal.classList.add('hidden');
  };

  // abrir signup (modal)
  signupBtn.onclick = () => {
    signupModal.classList.remove('hidden');
    loginDropdown.classList.add('hidden');
  };

  // cerrar manual
  closeLogin.onclick = () => loginDropdown.classList.add('hidden');
  closeSignup.onclick = () => signupModal.classList.add('hidden');

  // cerrar al hacer click afuera
  document.addEventListener('click', (e) => {
    const target = e.target as Node;

    if (!loginDropdown.contains(target) && !loginBtn.contains(target)) {
      loginDropdown.classList.add('hidden');
    }

    if (
      !signupModal.querySelector('.modal-box')!.contains(target) &&
      !signupBtn.contains(target)
    ) {
      signupModal.classList.add('hidden');
    }
  });
</script>
</body>
</html>
 
<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
 
  :root {
    --bg: #0d1117;
    --accent: #e8c84a;
    --border: rgba(255,255,255,0.07);
    --text-muted: rgba(200, 215, 225, 0.45);
  }
 
  html { scroll-behavior: smooth; }
 
  body {
    background: var(--bg);
    color: #cdd9e5;
    font-family: 'DM Sans', sans-serif;
    min-height: 100vh;
    overflow-x: hidden;
  }
 
 
  /* ── NAVBAR ── */
  .navbar {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 200;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 48px;
    height: 60px;
    background: rgba(13, 17, 23, 0.88);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--border);
    animation: slideDown 0.5s cubic-bezier(0.23, 1, 0.32, 1) both;
  }
  .nav-search {
    position: relative;
    display: flex;
    align-items: center;
  }
  .nav-search .search-icon {
    position: absolute;
    left: 12px;
    font-size: 17px;
    color: rgba(200, 215, 225, 0.35);
  }
  .nav-search input {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.09);
    border-radius: 6px;
    color: #f3f3f3;
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    font-weight: 300;
    padding: 7px 14px 7px 34px;
    width: 240px;
    outline: none;
    transition: border-color 0.2s, background 0.2s, width 0.3s;
  }
  .nav-search input:focus {
    border-color: rgba(232, 200, 74, 0.45);
    background: rgba(255,255,255,0.07);
    width: 900px;
  }
  .nav-right {
  position: relative;
  display: flex;
  align-items: center;
}

/* login */
.login-dropdown {
  position: absolute;
  top: 42px;
  right: 90px;
  background: #1c2229;
  padding: 14px;
  display: flex;
  align-items: center;
  gap: 10px;
  border-radius: 6px;
  z-index: 300;
  border: 1px solid rgba(255,255,255,0.08);
  animation: fadeDropdown 0.2s ease;
  box-shadow: 0 10px 25px rgba(0,0,0,0.35);ase;
}

.login-dropdown input {
  background: #2a313a;
  border: none;
  padding: 6px 8px;
  color: white;
  border-radius: 3px;
  font-size: 12px;
  width: 140px;
}

.login-actions {
  display: flex;
  align-items: center;
  gap: 10px;
}

.login-actions label {
  font-size: 11px;
  color: rgba(200, 215, 225, 0.45);
  display: flex;
  align-items: center;
  gap: 4px;
}

.forgot {
  font-size: 11px;
  color: #4caf50;
  text-decoration: none;
}

.signin-btn {
  background: #00c030;
  border: none;
  padding: 6px 10px;
  font-size: 12px;
  color: white;
  border-radius: 3px;
  cursor: pointer;
}

/* sign up */

.modal {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.65);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 400;
}

.modal-box {
  background: #161b22;
  padding: 30px;
  border-radius: 10px;
  width: 320px;
  display: flex;
  flex-direction: column;
  gap: 12px;
  position: relative;
  animation: fadeIn 0.2s ease;
}

.modal-box h2 {
  margin-bottom: 10px;
}

.modal-box input {
  padding: 8px;
  background: #0d1117;
  border: 1px solid rgba(255,255,255,0.08);
  color: white;
  border-radius: 5px;
}

.submit-btn {
  background: #e8c84a;
  border: none;
  padding: 8px;
  cursor: pointer;
  border-radius: 5px;
  font-weight: 500;
}

*/ cerrar */
.close {
  position: absolute;
  top: 10px;
  right: 12px;
  cursor: pointer;
  opacity: 0.6;
}
.auth-btn {
  background: var(--accent);
  border: none;
  color: #000;
  font-size: 12px;
  padding: 7px 12px;
  border-radius: 4px;
  cursor: pointer;
  margin-left: 10px;
  font-weight: 500;
}

.auth-btn.outline {
  background: transparent;
  border: 1px solid var(--accent);
  color: var(--accent);
}

.hidden {
  display: none;
}
  @keyframes slideDown {
    from { transform: translateY(-100%); opacity: 0; }
    to   { transform: translateY(0);     opacity: 1; }
  }
 
  .logo {
    display: flex;
    align-items: center;
    gap: 9px;
    text-decoration: none;
  }
  .logo-icon {
    font-size: 21px;
    color: var(--accent);
    line-height: 1;
    animation: pulse 3.5s ease-in-out infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.6; }
  }
  .logo-text {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 23px;
    letter-spacing: 0.14em;
    color: #fff;
    font-weight: 400;
  }
 
  .nav-links {
    display: flex;
    gap: 30px;
  }
  .nav-links a {
    color: var(--text-muted);
    text-decoration: none;
    font-size: 12.5px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 500;
    transition: color 0.22s ease;
    position: relative;
  }
  .nav-links a::after {
    content: '';
    position: absolute;
    bottom: -3px;
    left: 0; right: 0;
    height: 1px;
    background: var(--accent);
    transform: scaleX(0);
    transition: transform 0.22s ease;
    transform-origin: left;
  }
  .nav-links a:hover {
    color: #cdd9e5;
  }
  .nav-links a:hover::after {
    transform: scaleX(1);
  }
 
  .nav-right .tagline {
    font-size: 11px;
    letter-spacing: 0.12em;
    color: rgba(232,200,74,0.35);
    text-transform: uppercase;
    font-weight: 500;
  }
 
 
  @media (max-width: 700px) {
    .navbar { padding: 0 20px; }
    .nav-links { display: none; }
    .nav-right { display: none; }
  }
</style>
