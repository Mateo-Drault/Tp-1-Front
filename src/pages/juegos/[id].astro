const { id } = Astro.params as { id: keyof typeof juegos };
const juego = juegos[id];

if (!juego) return Astro.redirect("/");

const baseRating = juego.rating;
function getRatingDistribution(avg: number) {
  // Distribución gaussiana simulada centrada en avg
  const bars = [0.5, 1, 1.5, 2, 2.5, 3, 3.5, 4, 4.5, 5];
  return bars.map(star => {
    const diff = Math.abs(star - avg);
    const height = Math.max(4, Math.round(80 * Math.exp(-(diff * diff) / 0.6)));
    return { star, height };
  });
}
const distribution = getRatingDistribution(baseRating);
const totalRatings = "197K";
const totalFans = "42K";
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{juego.nombre} — Checkpoint</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet" />
</head>
<body>

  <!-- ───── NAVBAR ───── -->
  <nav class="navbar">
    <a href="/" class="logo">
      <span class="logo-icon">◈</span>
      <span class="logo-text">CHECKPOINT</span>
    </a>
  </nav>

  <!-- ───── HERO ───── -->
  <div class="hero-wrapper">
    <div class="hero-bg" style={`background-image: url(${juego.imagen})`}></div>
    <div class="hero-overlay"></div>
  </div>

  <!-- ───── MAIN CONTENT ───── -->
  <main class="main-content">
    <div class="game-card">

      <!-- POSTER -->
      <div class="poster-col">
        <div class="poster-wrap">
          <img class="poster" src={juego.imagen} alt={juego.nombre} />
        </div>
        <div class="poster-stats">
          <span title="Partidas registradas">🎮 2.8M</span>
          <span title="Reseñas">{totalRatings} reseñas</span>
          <span title="Fans">♥ {totalFans}</span>
        </div>
        <div class="watch-section">
          <p class="watch-label">DISPONIBLE EN</p>
          {juego.plataformas.map(p => (
            <span class="platform-tag">{p}</span>
          ))}
        </div>
      </div>

      <!-- INFO CENTRAL -->
      <div class="info-col">
        <div class="title-row">
          <h1 class="game-title">{juego.nombre}</h1>
          <span class="game-year">{juego.anio}</span>
        </div>
        <p class="game-dev">Desarrollado por <a href="#" class="dev-link">{juego.desarrollador}</a></p>

        <p class="game-desc">{juego.descripcion}</p>

        <div class="genres-row">
          {juego.generos.map(g => (
            <a href="#" class="genre-tag">{g}</a>
          ))}
        </div>

        <!-- TABS -->
        <div class="tabs">
          <button class="tab">DETALLES</button>
        </div>
      </div>

      <!-- RATING PANEL -->
      <div class="rating-col">
        <div class="rating-box">
          <div class="rating-actions">
          </div>

          <div class="rating-section">
            <p class="rating-label">PUNTUACIONES</p>
            <p class="fans-label">{totalFans} FANS</p>
          </div>

          <!-- Histograma -->
          <div class="histogram">
            {distribution.map(({ star, height }) => (
              <div class="bar-col">
                <div
                  class={`bar ${star <= Math.round(baseRating * 2) / 2 ? 'bar-filled' : 'bar-empty'}`}
                  style={`height: ${height}px`}
                ></div>
              </div>
            ))}
          </div>

          <div class="histogram-labels">
            <span>½</span>
            <span>5</span>
          </div>

          <!-- Promedio -->
          <div class="avg-row">
            <div class="stars-display">
              {[1,2,3,4,5].map(s => (
                <span class={`star ${s <= Math.round(baseRating) ? 'star-on' : 'star-off'}`}>★</span>
              ))}
            </div>
            <span class="avg-number">{baseRating.toFixed(1)}</span>
          </div>
        </div>
      </div>

    </div>
  </main>

</body>
</html>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: #0d1117;
    --surface: #161b22;
    --surface2: #1c2330;
    --border: rgba(255,255,255,0.07);
    --text: #cdd9e5;
    --text-muted: #768390;
    --accent: #e8c84a;
    --accent2: #58a6ff;
    --green: #3fb950;
    --font-display: 'Bebas Neue', sans-serif;
    --font-serif: 'DM Serif Display', serif;
    --font-body: 'DM Sans', sans-serif;
  }

  html { scroll-behavior: smooth; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--font-body);
    font-weight: 300;
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* ── NAVBAR ── */
  .navbar {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 40px;
    height: 56px;
    background: rgba(13, 17, 23, 0.92);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
  }
  .logo-icon {
    font-size: 20px;
    color: var(--accent);
    line-height: 1;
  }
  .logo-text {
    font-family: var(--font-display);
    font-size: 22px;
    letter-spacing: 0.12em;
    color: #fff;
  }

  .nav-links {
    display: flex;
    gap: 28px;
  }
  .nav-links a {
    color: var(--text-muted);
    text-decoration: none;
    font-size: 13px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 500;
    transition: color 0.2s;
  }
  .nav-links a:hover { color: var(--text); }

  .nav-actions {
    display: flex;
    gap: 10px;
    align-items: center;
  }
  .btn-secondary {
    color: var(--text-muted);
    text-decoration: none;
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.05em;
    transition: color 0.2s;
  }
  .btn-secondary:hover { color: var(--text); }
  .btn-primary {
    background: var(--accent);
    color: #000;
    text-decoration: none;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 7px 14px;
    border-radius: 4px;
    transition: opacity 0.2s;
  }
  .btn-primary:hover { opacity: 0.85; }

  /* ── HERO ── */
  .hero-wrapper {
    position: relative;
    height: 72vh;
    min-height: 480px;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center top;
    filter: saturate(0.7) brightness(0.6);
    transform: scale(1.04);
    animation: heroZoom 18s ease-out forwards;
  }

  @keyframes heroZoom {
    from { transform: scale(1.04); }
    to   { transform: scale(1.00); }
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to right,  #0d1117 0%,  rgba(13,17,23,0.55) 30%, transparent 58%),
      linear-gradient(to left,   rgba(13,17,23,0.45) 0%, transparent 45%),
      linear-gradient(to bottom, transparent 38%, rgba(13,17,23,0.85) 72%, #0d1117 100%);
  }

  /* ── MAIN CONTENT ── */
  .main-content {
    position: relative;
    z-index: 2;
    max-width: 1160px;
    margin: -180px auto 0;
    padding: 0 32px 80px;
    animation: fadeUp 0.6s ease both;
    animation-delay: 0.1s;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── GAME CARD ── */
  .game-card {
    display: grid;
    grid-template-columns: 200px 1fr 260px;
    gap: 32px;
    align-items: start;
  }

  /* ── POSTER COL ── */
  .poster-wrap {
    position: relative;
  }
  .poster {
    width: 100%;
    aspect-ratio: 3/4;
    object-fit: cover;
    border-radius: 8px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.7), 0 0 0 1px rgba(255,255,255,0.06);
    display: block;
  }

  .poster-stats {
    display: flex;
    gap: 12px;
    margin-top: 12px;
    font-size: 11.5px;
    color: var(--text-muted);
    flex-wrap: wrap;
    justify-content: center;
  }
  .poster-stats span { white-space: nowrap; }

  .watch-section {
    margin-top: 16px;
    padding-top: 14px;
    border-top: 1px solid var(--border);
  }
  .watch-label {
    font-size: 10px;
    letter-spacing: 0.12em;
    color: var(--text-muted);
    margin-bottom: 8px;
    font-weight: 500;
  }
  .platform-tag {
    display: inline-block;
    background: var(--surface2);
    border: 1px solid var(--border);
    color: var(--text-muted);
    font-size: 11px;
    padding: 3px 8px;
    border-radius: 3px;
    margin: 2px;
    letter-spacing: 0.04em;
  }

  /* ── INFO COL ── */
  .info-col {
    padding-top: 12px;
  }

  .title-row {
    display: flex;
    align-items: baseline;
    gap: 14px;
    flex-wrap: wrap;
  }

  .game-title {
    font-family: var(--font-display);
    font-size: 52px;
    letter-spacing: 0.02em;
    line-height: 1;
    color: #fff;
    font-weight: 400;
  }

  .game-year {
    font-family: var(--font-body);
    font-size: 18px;
    color: var(--text-muted);
    font-weight: 300;
  }

  .game-dev {
    font-size: 13px;
    color: var(--text-muted);
    margin-top: 6px;
    font-style: italic;
  }
  .dev-link {
    color: var(--accent2);
    text-decoration: none;
