---
import axios from 'axios'

const API_URL = 'http://localhost:3000/api'

const { id } = Astro.params as { id: string }
let juego = null
let error = null

try {
  const res = await axios.get(`${API_URL}/games/${id}`)
  juego = res.data
} catch (err: any) {
  error = err.message
}

if (!juego) return Astro.redirect('/')

const baseRating = juego.rating || 3.5

function getRatingDistribution(avg: number) {
  const bars = [0.5, 1, 1.5, 2, 2.5, 3, 3.5, 4, 4.5, 5]
  return bars.map(star => {
    const diff = Math.abs(star - avg)
    const height = Math.max(4, Math.round(80 * Math.exp(-(diff * diff) / 0.6)))
    return { star, height }
  })
}

const distribution = getRatingDistribution(baseRating)
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{juego.name} — Checkpoint</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet" />
</head>
<body>

  <nav class="navbar">
    <a href="/" class="logo">
      <span class="logo-icon">◈</span>
      <span class="logo-text">CHECKPOINT</span>
    </a>
  </nav>

  <div class="hero-wrapper">
    <div class="hero-bg" style={`background-image: url(${juego.image})`}></div>
    <div class="hero-overlay"></div>
  </div>

  <main class="main-content">
    <div class="game-card">
      <div class="poster-col">
        <div class="poster-wrap">
          <img class="poster" src={juego.cover || juego.image} alt={juego.name} />
        </div>
        <div class="watch-section">
          <p class="watch-label">PLATAFORMAS</p>
          {juego.platforms?.map((p: string) => (
            <span class="platform-tag">{p}</span>
          ))}
        </div>
      </div>

      <div class="info-col">
        <div class="title-row">
          <h1 class="game-title">{juego.name}</h1>
          <span class="game-year">{juego.released?.split('-')[0]}</span>
        </div>
        <p class="game-dev">Desarrollado por {juego.developers?.join(', ')}</p>
        <p class="game-desc">{juego.description}</p>

        <div class="genres-row">
          {juego.genres?.map((g: string) => (
            <span class="genre-tag">{g}</span>
          ))}
        </div>
      </div>

      <div class="rating-col">
        <div class="rating-box">
          <div class="histogram">
            {distribution.map(({ star, height }) => (
              <div class="bar-col">
                <div
                  class={`bar ${star <= Math.round(baseRating * 2) / 2 ? 'bar-filled' : 'bar-empty'}`}
                  style={`height: ${height}px`}
                ></div>
              </div>
            ))}
          </div>

          <div class="avg-row">
            <div class="stars-display">
              {[1,2,3,4,5].map(s => (
                <span class={`star ${s <= Math.round(baseRating) ? 'star-on' : 'star-off'}`}>★</span>
              ))}
            </div>
            <span class="avg-number">{baseRating.toFixed(1)}</span>
          </div>
        </div>
      </div>
    </div>
  </main>

</body>
</html>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: #0d1117;
    --surface: #161b22;
    --surface2: #1c2330;
    --border: rgba(255,255,255,0.07);
    --text: #cdd9e5;
    --text-muted: #768390;
    --accent: #e8c84a;
    --accent2: #58a6ff;
    --green: #3fb950;
    --font-display: 'Bebas Neue', sans-serif;
    --font-serif: 'DM Serif Display', serif;
    --font-body: 'DM Sans', sans-serif;
  }

  html { scroll-behavior: smooth; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--font-body);
    font-weight: 300;
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* ── NAVBAR ── */
  .navbar {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 40px;
    height: 56px;
    background: rgba(13, 17, 23, 0.92);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
  }
  .logo-icon {
    font-size: 20px;
    color: var(--accent);
    line-height: 1;
  }
  .logo-text {
    font-family: var(--font-display);
    font-size: 22px;
    letter-spacing: 0.12em;
    color: #fff;
  }

  .nav-links {
    display: flex;
    gap: 28px;
  }
  .nav-links a {
    color: var(--text-muted);
    text-decoration: none;
    font-size: 13px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 500;
    transition: color 0.2s;
  }
  .nav-links a:hover { color: var(--text); }

  .nav-actions {
    display: flex;
    gap: 10px;
    align-items: center;
  }
  .btn-secondary {
    color: var(--text-muted);
    text-decoration: none;
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.05em;
    transition: color 0.2s;
  }
  .btn-secondary:hover { color: var(--text); }
  .btn-primary {
    background: var(--accent);
    color: #000;
    text-decoration: none;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 7px 14px;
    border-radius: 4px;
    transition: opacity 0.2s;
  }
  .btn-primary:hover { opacity: 0.85; }

  /* ── HERO ── */
  .hero-wrapper {
    position: relative;
    height: 72vh;
    min-height: 480px;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center top;
    filter: saturate(0.7) brightness(0.6);
    transform: scale(1.04);
    animation: heroZoom 18s ease-out forwards;
  }

  @keyframes heroZoom {
    from { transform: scale(1.04); }
    to   { transform: scale(1.00); }
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to right,  #0d1117 0%,  rgba(13,17,23,0.55) 30%, transparent 58%),
      linear-gradient(to left,   rgba(13,17,23,0.45) 0%, transparent 45%),
      linear-gradient(to bottom, transparent 38%, rgba(13,17,23,0.85) 72%, #0d1117 100%);
  }

  /* ── MAIN CONTENT ── */
  .main-content {
    position: relative;
    z-index: 2;
    max-width: 1160px;
    margin: -180px auto 0;
    padding: 0 32px 80px;
    animation: fadeUp 0.6s ease both;
    animation-delay: 0.1s;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── GAME CARD ── */
  .game-card {
    display: grid;
    grid-template-columns: 200px 1fr 260px;
    gap: 32px;
    align-items: start;
  }

  /* ── POSTER COL ── */
  .poster-wrap {
    position: relative;
  }
  .poster {
    width: 100%;
    aspect-ratio: 3/4;
    object-fit: cover;
    border-radius: 8px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.7), 0 0 0 1px rgba(255,255,255,0.06);
    display: block;
  }

  .poster-stats {
    display: flex;
    gap: 12px;
    margin-top: 12px;
    font-size: 11.5px;
    color: var(--text-muted);
    flex-wrap: wrap;
    justify-content: center;
  }
  .poster-stats span { white-space: nowrap; }

  .watch-section {
    margin-top: 16px;
    padding-top: 14px;
    border-top: 1px solid var(--border);
  }
  .watch-label {
    font-size: 10px;
    letter-spacing: 0.12em;
    color: var(--text-muted);
    margin-bottom: 8px;
    font-weight: 500;
  }
  .platform-tag {
    display: inline-block;
    background: var(--surface2);
    border: 1px solid var(--border);
    color: var(--text-muted);
    font-size: 11px;
    padding: 3px 8px;
    border-radius: 3px;
    margin: 2px;
    letter-spacing: 0.04em;
  }

  /* ── INFO COL ── */
  .info-col {
    padding-top: 12px;
  }

  .title-row {
    display: flex;
    align-items: baseline;
    gap: 14px;
    flex-wrap: wrap;
  }

  .game-title {
    font-family: var(--font-display);
    font-size: 52px;
    letter-spacing: 0.02em;
    line-height: 1;
    color: #fff;
    font-weight: 400;
  }

  .game-year {
    font-family: var(--font-body);
    font-size: 18px;
    color: var(--text-muted);
    font-weight: 300;
  }

  .game-dev {
    font-size: 13px;
    color: var(--text-muted);
    margin-top: 6px;
    font-style: italic;
  }
  .dev-link {
    color: var(--accent2);
    text-decoration: none;
  }
  .dev-link:hover { text-decoration: underline; }

  .game-desc {
    margin-top: 18px;
    font-size: 14.5px;
    line-height: 1.75;
    color: var(--text);
    max-width: 560px;
    font-weight: 300;
  }

  .genres-row {
    margin-top: 14px;
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .genre-tag {
    text-decoration: none;
    color: var(--text-muted);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border: 1px solid var(--border);
    padding: 4px 10px;
    border-radius: 2px;
    transition: border-color 0.2s, color 0.2s;
  }
  .genre-tag:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .tabs {
    display: flex;
    gap: 0;
    margin-top: 28px;
    border-bottom: 1px solid var(--border);
  }
  .tab {
    background: none;
    border: none;
    color: var(--text-muted);
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 10px 16px;
    cursor: pointer;
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
    transition: color 0.2s, border-color 0.2s;
  }
  .tab:hover { color: var(--text); }
  .tab.active {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }

  /* ── RATING COL ── */
  .rating-col {
    padding-top: 12px;
  }

  .rating-box {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 18px 16px;
  }

  .rating-actions {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: 20px;
  }
  .action-btn {
    width: 100%;
    padding: 10px;
    border-radius: 5px;
    border: none;
    font-family: var(--font-body);
    font-size: 12.5px;
    font-weight: 500;
    cursor: pointer;
    letter-spacing: 0.04em;
    transition: opacity 0.2s;
  }
  .action-btn:hover { opacity: 0.82; }
  .primary-action {
    background: var(--surface2);
    color: var(--text);
    border: 1px solid var(--border);
  }
  .secondary-action {
    background: transparent;
    color: var(--text-muted);
    border: 1px solid var(--border);
  }

  .rating-section {
    display: flex;
    justify-content: space-between;
    margin-bottom: 10px;
  }
  .rating-label,
  .fans-label {
    font-size: 10px;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    font-weight: 500;
  }

  /* ── HISTOGRAMA ── */
  .histogram {
    display: flex;
    align-items: flex-end;
    gap: 2px;
    height: 80px;
    padding: 0 2px;
  }
  .bar-col {
    flex: 1;
    display: flex;
    align-items: flex-end;
    justify-content: center;
  }
  .bar {
    width: 100%;
    max-width: 18px;
    border-radius: 2px 2px 0 0;
    transition: height 0.4s ease;
  }
  .bar-filled {
    background: linear-gradient(to top, var(--accent), rgba(232,200,74,0.55));
  }
  .bar-empty {
    background: var(--surface2);
  }

  .histogram-labels {
    display: flex;
    justify-content: space-between;
    font-size: 10px;
    color: var(--text-muted);
    margin-top: 4px;
    padding: 0 2px;
  }

  /* ── PROMEDIO ── */
  .avg-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 12px;
    padding-top: 12px;
    border-top: 1px solid var(--border);
  }
  .stars-display {
    display: flex;
    gap: 1px;
  }
  .star {
    font-size: 16px;
    line-height: 1;
  }
  .star-on  { color: var(--accent); }
  .star-off { color: var(--surface2); }

  .avg-number {
    font-family: var(--font-display);
    font-size: 34px;
    color: #fff;
    line-height: 1;
    letter-spacing: 0.02em;
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 900px) {
    .game-card {
      grid-template-columns: 160px 1fr;
      grid-template-rows: auto auto;
    }
    .rating-col {
      grid-column: 1 / -1;
    }
    .game-title { font-size: 38px; }
  }

  @media (max-width: 600px) {
    .navbar { padding: 0 16px; }
    .nav-links { display: none; }
    .main-content { padding: 0 16px 60px; margin-top: -120px; }
    .game-card {
      grid-template-columns: 1fr;
    }
    .poster-wrap { max-width: 180px; margin: 0 auto; }
  }
</style>